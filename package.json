{
    "name": "@tinycld/bootstrap",
    "version": "2.4.2",
    "description": "Scaffolder for @tinycld feature packages",
    "type": "module",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/tinycld/bootstrap.git"
    },
    "bin": {
        "bootstrap": "dist/index.js"
    },
    "files": [
        "dist",
        "templates"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "clean": "rm -rf dist",
        "build": "pnpm run clean && tsc",
        "dev": "tsx src/index.ts",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "typecheck": "tsc --noEmit",
        "checks": "pnpm run lint && pnpm run typecheck",
        "test": "vitest run --exclude '**/tests/integration/**'",
        "test:integration": "vitest run tests/integration",
        "prepublishOnly": "pnpm run checks && pnpm run test && pnpm run build",
        "release": "pnpm publish"
    },
    "dependencies": {
        "@clack/prompts": "^0.8.0",
        "picocolors": "^1.1.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.12",
        "@types/node": "^22.10.0",
        "tsx": "^4.21.0",
        "typescript": "^5.9.0",
        "vitest": "^3.0.0"
    },
    "engines": {
        "node": ">=24"
    },
    "packageManager": "pnpm@11.3.0"
}
